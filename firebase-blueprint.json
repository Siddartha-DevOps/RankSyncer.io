{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "An organic domain being tracked and optimized",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "visibilityIndex": { "type": "integer" },
        "avgPosition": { "type": "number" },
        "organicTraffic": { "type": "integer" },
        "cmsPlatform": { "type": "string", "enum": ["wordpress", "webflow", "ghost", "custom"] },
        "crawlStatus": { "type": "string", "enum": ["STALE", "CRAWLING", "COMPLETED", "FAILED"] },
        "lastCrawledAt": { "type": "string", "format": "date-time" },
        "crawlHistory": { "type": "array" },
        "niche": { "type": "string" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "name", "domain", "ownerId"]
    },
    "Keyword": {
      "title": "Keyword",
      "description": "A target search term within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "term": { "type": "string" },
        "volume": { "type": "integer" },
        "difficulty": { "type": "integer" },
        "intent": { "type": "string", "enum": ["Informational", "Transactional", "Commercial", "Navigational"] },
        "currentRank": { "type": "integer" },
        "previousRank": { "type": "integer" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "projectId", "term", "ownerId"]
    },
    "Article": {
      "title": "Article",
      "description": "An SEO article drafted for publication",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "targetKeyword": { "type": "string" },
        "wordCount": { "type": "integer" },
        "seoScore": { "type": "integer" },
        "status": { "type": "string", "enum": ["Draft", "Reviewing", "Ready", "Published"] },
        "content": { "type": "string" },
        "lastEdited": { "type": "string", "format": "date-time" },
        "metaDescription": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "projectId", "title", "ownerId"]
    },
    "CrawlerLog": {
      "title": "CrawlerLog",
      "description": "System crawler execution history event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["info", "success", "warn", "error"] },
        "message": { "type": "string" },
        "module": { "type": "string", "enum": ["SERP_CRAWLER", "BACKLINK_CHECK", "AI_WRITER", "CMS_SYNC"] },
        "ownerId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["id", "timestamp", "type", "message", "ownerId"]
    },
    "ContentPlan": {
      "title": "ContentPlan",
      "description": "30-Day automated AI Content Plan master",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerId": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "niche": { "type": "string" },
        "targetKeywords": { "type": "array" },
        "targetCountry": { "type": "string" },
        "targetAudience": { "type": "string" },
        "days": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "generating", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "tokenCount": { "type": "integer" }
      },
      "required": ["id", "projectId", "ownerId", "websiteUrl", "niche", "days", "status"]
    },
    "ContentPlanItem": {
      "title": "ContentPlanItem",
      "description": "An article idea/topic on a specific day of a Content Plan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "planId": { "type": "string" },
        "projectId": { "type": "string" },
        "day": { "type": "integer" },
        "title": { "type": "string" },
        "targetKeyword": { "type": "string" },
        "searchIntent": { "type": "string" },
        "estimatedTraffic": { "type": "integer" },
        "articleType": { "type": "string" },
        "publishingCadence": { "type": "string" },
        "status": { "type": "string", "enum": ["planned", "generated", "published"] },
        "approved": { "type": "boolean" },
        "draftArticleId": { "type": "string" }
      },
      "required": ["id", "planId", "projectId", "day", "title", "targetKeyword", "status", "approved"]
    },
    "ContentPlanGeneration": {
      "title": "ContentPlanGeneration",
      "description": "Generation transaction and logger details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "planId": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerId": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "processing", "completed", "failed"] },
        "error": { "type": "string" },
        "retryCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "planId", "projectId", "ownerId", "status", "retryCount"]
    },
    "KeywordDiscovery": {
      "title": "KeywordDiscovery",
      "description": "An AI-discovered keyword opportunity with metrics and topical reasoning",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "keyword": { "type": "string" },
        "intent": { "type": "string" },
        "volume": { "type": "integer" },
        "difficulty": { "type": "integer" },
        "cpc": { "type": "number" },
        "cluster": { "type": "string" },
        "opportunityScore": { "type": "integer" },
        "reasoning": { "type": "string" },
        "suggestedTitle": { "type": "string" },
        "generatedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "projectId", "keyword", "ownerId"]
    },
    "KeywordCluster": {
      "title": "KeywordCluster",
      "description": "A group of semantically clustered keyword terms",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "clusterName": { "type": "string" },
        "primaryKeyword": { "type": "string" },
        "supportingKeywords": { "type": "array" },
        "clusterDifficulty": { "type": "integer" },
        "contentOpportunityScore": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "projectId", "clusterName", "ownerId"]
    },
    "KeywordGenerationLog": {
      "title": "KeywordGenerationLog",
      "description": "Background execution logs for discovery queue tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "processing", "completed", "failed"] },
        "totalKeywords": { "type": "integer" },
        "niche": { "type": "string" },
        "error": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "projectId", "status", "ownerId"]
    },
    "KeywordCache": {
      "title": "KeywordCache",
      "description": "Cached repeated keyword opportunity generations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "domain": { "type": "string" },
        "niche": { "type": "string" },
        "rawResultJson": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "projectId", "domain", "ownerId"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Root collection for SEO active domains"
    },
    "/projects/{projectId}/keywords/{keywordId}": {
      "schema": "Keyword",
      "description": "Keywords tracked inside of specific projects"
    },
    "/projects/{projectId}/articles/{articleId}": {
      "schema": "Article",
      "description": "Generated content briefs and posts targeting keyword terms"
    },
    "/projects/{projectId}/logs/{logId}": {
      "schema": "CrawlerLog",
      "description": "System diagnostic and crawling telemetry history logs"
    },
    "/projects/{projectId}/content_plans/{planId}": {
      "schema": "ContentPlan",
      "description": "30-Day automated AI Content Plans"
    },
    "/projects/{projectId}/content_plans/{planId}/items/{itemId}": {
      "schema": "ContentPlanItem",
      "description": "One article topic per day inside of a Content Plan"
    },
    "/projects/{projectId}/content_plans/{planId}/generations/{generationId}": {
      "schema": "ContentPlanGeneration",
      "description": "Database track for asynchronous job queueing"
    },
    "/projects/{projectId}/keyword_discoveries/{discoveryId}": {
      "schema": "KeywordDiscovery",
      "description": "AI discovered keyword lists"
    },
    "/projects/{projectId}/keyword_clusters/{clusterId}": {
      "schema": "KeywordCluster",
      "description": "Semantically-grouped clusters of target keyword parameters"
    },
    "/projects/{projectId}/keyword_generation_logs/{logId}": {
      "schema": "KeywordGenerationLog",
      "description": "System status tracking log during background queue triggers"
    },
    "/projects/{projectId}/keyword_cache/{cacheId}": {
      "schema": "KeywordCache",
      "description": "Local cached results for repeated niche opportunity research requests"
    }
  }
}
